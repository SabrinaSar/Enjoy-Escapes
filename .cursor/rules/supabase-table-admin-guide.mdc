## Admin Panel Management

### 5. Admin Page Structure
Create admin pages following the established pattern:

```typescript
// app/admin/new-table/page.tsx
import { createClient } from "@/utils/supabase/server";
import NewTableAdmin from "./components/NewTableAdmin";

export default async function NewTableAdminPage() {
  const supabase = await createClient();
  
  const { data: items } = await supabase
    .from("new_table_name")
    .select(`
      *,
      new_table_related (*)
    `)
    .order("created_at", { ascending: false });

  return <NewTableAdmin initialItems={items || []} />;
}
```

### 6. Admin Component with CRUD Operations
```typescript
// app/admin/new-table/components/NewTableAdmin.tsx
"use client";

import { useState } from "react";
import { createClient } from "@/utils/supabase/client";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Switch } from "@/components/ui/switch";

export default function NewTableAdmin({ initialItems }) {
  const [items, setItems] = useState(initialItems);
  const [isLoading, setIsLoading] = useState(false);
  const supabase = createClient();

  const handleCreate = async (newItem) => {
    setIsLoading(true);
    try {
      const { data, error } = await supabase
        .from("new_table_name")
        .insert([newItem])
        .select()
        .single();

      if (error) throw error;
      setItems([data, ...items]);
    } catch (error) {
      console.error("Error creating item:", error);
    } finally {
      setIsLoading(false);
    }
  };

  const handleUpdate = async (id, updates) => {
    setIsLoading(true);
    try {
      const { data, error } = await supabase
        .from("new_table_name")
        .update(updates)
        .eq("id", id)
        .select()
        .single();

      if (error) throw error;
      setItems(items.map(item => item.id === id ? data : item));
    } catch (error) {
      console.error("Error updating item:", error);
    } finally {
      setIsLoading(false);
    }
  };

  const handleDelete = async (id) => {
    setIsLoading(true);
    try {
      const { error } = await supabase
        .from("new_table_name")
        .delete()
        .eq("id", id);

      if (error) throw error;
      setItems(items.filter(item => item.id !== id));
    } catch (error) {
      console.error("Error deleting item:", error);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="space-y-6">
      {/* Admin interface JSX */}
    </div>
  );
}
```

### 7. Form Components
Create reusable form components for consistent admin interfaces:

```typescript
// app/admin/components/NewTableForm.tsx
"use client";

import { useState } from "react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Switch } from "@/components/ui/switch";

interface Props {
  item?: any;
  onSubmit: (data: any) => void;
  isLoading?: boolean;
}

export default function NewTableForm({ item, onSubmit, isLoading }: Props) {
  const [formData, setFormData] = useState({
    name: item?.name || "",
    description: item?.description || "",
    is_active: item?.is_active ?? true,
    sort_order: item?.sort_order || 0,
  });

  const handleSubmit = (e) => {
    e.preventDefault();
    onSubmit(formData);
  };

  return (
    <form onSubmit={handleSubmit} className="space-y-4">
      <div>
        <label className="block text-sm font-medium mb-1">Name</label>
        <Input
          value={formData.name}
          onChange={(e) => setFormData({ ...formData, name: e.target.value })}
          required
        />
      </div>
      
      <div>
        <label className="block text-sm font-medium mb-1">Description</label>
        <Textarea
          value={formData.description}
          onChange={(e) => setFormData({ ...formData, description: e.target.value })}
        />
      </div>
      
      <div className="flex items-center space-x-2">
        <Switch
          checked={formData.is_active}
          onCheckedChange={(checked) => setFormData({ ...formData, is_active: checked })}
        />
        <label className="text-sm font-medium">Active</label>
      </div>
      
      <div>
        <label className="block text-sm font-medium mb-1">Sort Order</label>
        <Input
          type="number"
          value={formData.sort_order}
          onChange={(e) => setFormData({ ...formData, sort_order: parseInt(e.target.value) })}
        />
      </div>
      
      <Button type="submit" disabled={isLoading}>
        {isLoading ? "Saving..." : item ? "Update" : "Create"}
      </Button>
    </form>
  );
}
```

## Best Practices

### 8. TypeScript Types
Always create proper TypeScript interfaces:

```typescript
// types/database.ts
export interface NewTableItem {
  id: string;
  name: string;
  description?: string;
  is_active: boolean;
  sort_order: number;
  created_at: string;
  updated_at: string;
  new_table_related?: NewTableRelated[];
}

export interface NewTableRelated {
  id: string;
  new_table_id: string;
  key: string;
  value: string;
  created_at: string;
}
```

### 9. Error Handling
Always implement proper error handling:

```typescript
const handleOperation = async () => {
  try {
    setIsLoading(true);
    const { data, error } = await supabase.from("table").select();
    
    if (error) {
      console.error("Database error:", error);
      // Show user-friendly error message
      return;
    }
    
    // Handle success
  } catch (error) {
    console.error("Unexpected error:", error);
    // Show generic error message
  } finally {
    setIsLoading(false);
  }
};
```

